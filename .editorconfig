root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 2

# Rust and C examples use 4-space indentation.
[*.{rs,c,h}]
indent_size = 4

# Makefiles require literal tabs for recipe lines.
[Makefile]
indent_style = tab

[*.md]
max_line_length = unset
